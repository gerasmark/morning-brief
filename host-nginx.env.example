# Path prefix exposed by the existing host nginx.
# Keep the leading slash and omit the trailing slash.
APP_BASE_PATH=/morning-brief

# Local loopback port the internal containerized nginx listens on.
HOST_BIND_PORT=3001

# Hidden admin entry route inside the React app.
ADMIN_ENTRY_PATH=/ops-f3d8a1

# Local loopback port published by the Keycloak container for host nginx.
KEYCLOAK_BIND_PORT=8081

# Public Keycloak URL exposed through host nginx.
KEYCLOAK_HOSTNAME=https://gerasmark.com/identity

# Keycloak database.
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me

# Bootstrap admin for managing the Keycloak server itself.
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=change-me
