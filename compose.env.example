# Public DNS name that points to your VM.
APP_DOMAIN=brief.example.com

# Email used for Let's Encrypt expiry notices.
LETSENCRYPT_EMAIL=admin@example.com

# Set to 1 only while testing issuance against the staging CA.
LETSENCRYPT_STAGING=0

# Set to 1 if you need to replace an existing cert, such as staging -> production.
CERTBOT_FORCE_RENEWAL=0

# How often nginx reloads its config to pick up renewed certificates.
NGINX_RELOAD_INTERVAL_SECONDS=21600

# How often the renewal container checks Let's Encrypt.
CERTBOT_RENEW_INTERVAL_SECONDS=43200
